<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0D0D0D">
  <meta name="color-scheme" content="dark">
  <meta name="description" content="Detail game di GameHub. Lihat informasi lengkap, screenshot, dan download game.">
  <meta name="robots" content="index, follow">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Detail Game - GameHub">
  <meta property="og:description" content="Informasi lengkap game di GameHub.">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Detail Game - GameHub">
  <meta name="twitter:description" content="Informasi lengkap game di GameHub.">

  <!-- PWA -->
  <link rel="manifest" href="manifest.json">
  <link rel="apple-touch-icon" href="assets/icons/icon-192x192.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="GameHub">

  <title>Detail Game - GameHub</title>

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Styles -->
  <link rel="stylesheet" href="css/style.css">
  <link rel="stylesheet" href="css/navbar.css">
  <link rel="stylesheet" href="css/home.css">
  <link rel="stylesheet" href="css/detail.css">
  <link rel="stylesheet" href="css/search.css">
  <link rel="stylesheet" href="css/animation.css">
  <link rel="stylesheet" href="css/responsive.css">
  <link rel="stylesheet" href="css/profile.css">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="assets/icons/favicon.png">
</head>
<body>
  <!-- Detail Page -->
  <main class="page page-enter" id="detailPage">
    <!-- Detail Banner -->
    <div class="detail-banner" id="detailBanner">
      <div class="skeleton skeleton-banner" style="width: 100%; height: 100%;"></div>
      <div class="detail-banner__gradient"></div>
      <div class="detail-banner__actions">
        <button class="detail-banner__btn" id="backBtn" aria-label="Kembali">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <div style="display: flex; gap: 8px;">
          <button class="detail-banner__btn" id="shareBtn" aria-label="Bagikan">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          </button>
          <button class="detail-banner__btn" id="favoriteBtn" aria-label="Favorit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Detail Header -->
    <div class="detail-header" id="detailHeader">
      <div class="detail-header__inner">
        <div class="skeleton skeleton-icon" style="width: 88px; height: 88px; border-radius: var(--radius-xl);"></div>
        <div class="detail-header__info">
          <div class="skeleton skeleton-text" style="width: 70%;"></div>
          <div class="skeleton skeleton-text" style="width: 50%;"></div>
          <div class="skeleton skeleton-text" style="width: 40%; margin-top: 8px;"></div>
        </div>
      </div>
    </div>

    <!-- Detail Meta -->
    <div class="detail-meta" id="detailMeta">
      <div class="detail-meta__item">
        <div class="skeleton skeleton-text" style="width: 80%; margin: 0 auto;"></div>
        <div class="skeleton skeleton-text" style="width: 60%; margin: 4px auto 0;"></div>
      </div>
      <div class="detail-meta__item">
        <div class="skeleton skeleton-text" style="width: 80%; margin: 0 auto;"></div>
        <div class="skeleton skeleton-text" style="width: 60%; margin: 4px auto 0;"></div>
      </div>
      <div class="detail-meta__item">
        <div class="skeleton skeleton-text" style="width: 80%; margin: 0 auto;"></div>
        <div class="skeleton skeleton-text" style="width: 60%; margin: 4px auto 0;"></div>
      </div>
    </div>

    <!-- Detail Actions -->
    <div class="detail-actions" id="detailActions" style="display: none;">
      <a href="#" class="btn btn--primary btn--large" id="downloadBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download
      </a>
      <button class="btn btn--secondary btn--icon" id="copyLinkBtn" aria-label="Salin link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>

    <!-- Detail Content -->
    <div class="detail-content" id="detailContent">
      <!-- Description -->
      <section class="detail-section" id="descriptionSection" style="display: none;">
        <h3 class="detail-section__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Deskripsi
        </h3>
        <div class="detail-description" id="gameDescription"></div>
      </section>

      <!-- Screenshots -->
      <section class="detail-section" id="screenshotsSection" style="display: none;">
        <h3 class="detail-section__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          Screenshot
        </h3>
        <div id="screenshotsContainer"></div>
      </section>

      <!-- Features -->
      <section class="detail-section" id="featuresSection" style="display: none;">
        <h3 class="detail-section__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Fitur
        </h3>
        <div class="feature-list" id="featureList"></div>
      </section>

      <!-- Changelog -->
      <section class="detail-section" id="changelogSection" style="display: none;">
        <h3 class="detail-section__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          Changelog
        </h3>
        <div class="changelog" id="changelogContent"></div>
      </section>
    </div>

    <!-- Related Games -->
    <section class="related-games" id="relatedGamesSection" style="display: none;">
      <div class="section__header">
        <h2 class="section__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Game Serupa
        </h2>
      </div>
      <div class="games-grid--horizontal" id="relatedGamesGrid"></div>
    </section>
  </main>

  <!-- Bottom Navigation -->
  <nav class="bottom-nav" role="navigation" aria-label="Navigasi utama">
        <div class="bottom-nav__inner">
      <a href="index.html" class="bottom-nav__item" data-page="home" aria-label="Beranda">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Beranda</span>
        <div class="ripple-container"></div>
      </a>
      <a href="search.html" class="bottom-nav__item" data-page="search" aria-label="Cari">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span>Cari</span>
        <div class="ripple-container"></div>
      </a>
      <a href="downloads.html" class="bottom-nav__item" data-page="downloads" aria-label="Unduhan">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span>Unduhan</span>
        <div class="ripple-container"></div>
      </a>
      <a href="favorites.html" class="bottom-nav__item" data-page="favorites" aria-label="Favorit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span>Favorit</span>
        <div class="ripple-container"></div>
      </a>
      <a href="profile.html" class="bottom-nav__item" data-page="profile" aria-label="Profil">
        <span data-nav-avatar class="avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        <span>Profil</span>
        <div class="ripple-container"></div>
      </a>
    </div></nav>

  <!-- Firebase & GameHub account scripts -->
  <script src="https://www.gstatic.com/firebasejs/10.13.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.13.0/firebase-auth-compat.js"></script>
  <script src="js/firebase-config.js"></script>
  <script src="js/storage.js"></script>
  <script src="js/auth.js"></script>
  <script src="js/context-menu.js"></script>
  <script type="module" src="js/detail.js"></script>

  <!-- Scripts -->
  <!-- js/detail.js (data-fetching module) belum diunggah ke project ini;
       js/detail-actions.js di atas menangani render dasar + tombol favorit/unduhan -->

  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('service-worker.js').catch(() => {});
    }
  </script>
</body>
</html>
